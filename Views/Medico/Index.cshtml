@model IEnumerable<CitasAPP.Models.Medico>

<h2>Directorio de Médicos</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre Completo</th>
            <th>Especialidad</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var medico in Model)
        {
            <tr>
                <td>@medico.Nombre @medico.Apellido</td>
                <td>@medico.Especialidad</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@medico.Id">Ver Detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>