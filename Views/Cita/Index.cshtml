@model IEnumerable<CitasAPP.Models.Cita>

<h2>Agenda Completa de Citas</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Fecha y Hora</th>
            <th>ID Paciente</th>
            <th>ID Médico</th>
            <th>Motivo</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cita in Model)
        {
            <tr>
                <td>@cita.Fecha a las @cita.Hora</td>
                <td>Paciente #@cita.PacienteId</td>
                <td>Médico #@cita.MedicoId</td>
                <td>@cita.Motivo</td>
                <td>@cita.Estado</td>
            </tr>
        }
    </tbody>
</table>